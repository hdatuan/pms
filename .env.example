# =========================================================================
# Docker Compose Environment Configuration Template (.env.example)
# Instructions: Copy this file to '.env' and edit the values as needed
# =========================================================================

# Database name and MySQL Root password
MYSQL_DATABASE=pms
MYSQL_ROOT_PASSWORD=admin

# MySQL host port mapping (for external DB clients)
MYSQL_PORT=3306

# Database credentials used by the Web Application
DB_USER=root
DB_PASS=admin
